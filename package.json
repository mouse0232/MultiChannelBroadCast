    "@sentry/astro": "^8.27.0",
    "cheerio": "^1.0.0",
    "dayjs": "^1.11.13",
    "flourite": "^1.3.0",
    "lru-cache": "^11.0.0",
    "ofetch": "^1.3.4",
    "prismjs": "^1.29.0",
    "prismjs-components-importer": "^0.2.0",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "^11.0.4",
    "@astrojs/netlify": "^5.5.1",
    "@astrojs/node": "^8.3.3",
    "@astrojs/vercel": "^7.8.0",
    "@types/prismjs": "^1.26.4",
    "astro": "^4.15.1",
    "astro-seo": "^0.8.4",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.5",
    "postcss-nesting": "^13.0.0",
    "std-env": "^3.7.0"
