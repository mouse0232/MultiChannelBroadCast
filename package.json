{
  "name": "multi-channel-broadcast",
  "type": "module",
  "version": "1.0.0",
  "description": "Multi-channel Telegram to microblog converter",
  "private": true,
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node scripts/prebuild-cache.js && node scripts/generate-cache-module.js && astro build",
    "build:node": "node scripts/prebuild-cache.js && node scripts/generate-cache-module.js && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prebuild": "node scripts/prebuild-cache.js"
