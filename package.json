{
  "name": "multi-channel-broadcast",
  "type": "module",
  "version": "1.0.0",
  "description": "Multi-channel Telegram to microblog converter",
  "private": true,
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "[ -f wrangler.toml ] && mv wrangler.toml wrangler.toml.bak; SERVER_ADAPTER=cloudflare_pages astro build; [ -f wrangler.toml.bak ] && mv wrangler.toml.bak wrangler.toml",
    "build:node": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "docker:start": "node --experimental-vm-modules src/worker-mock/index.js"
  },
  "keywords": [
    "telegram",
    "microblog",
    "multi-channel",
    "astro"
  ],
  "author": "banlan",
  "license": "MIT",
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@sentry/astro": "^10.53.1",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.77.3",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "flourite": "^1.3.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.5.0",
    "node-cron": "^4.2.1",
    "ofetch": "^1.5.1",
    "prismjs": "^1.30.0",
    "prismjs-components-importer": "^0.2.0",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@astrojs/cloudflare": "13.5.4",
    "@astrojs/netlify": "7.0.10",
    "@astrojs/node": "9.5.2",
    "@astrojs/vercel": "9.0.4",
    "@types/prismjs": "^1.26.6",
    "astro": "6.3.7",
    "astro-seo": "^1.1.0",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.32",
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.1",
    "postcss-nesting": "^14.0.0",
    "std-env": "^4.1.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  },
  "browserslist": [
    "defaults"
  ]
}
