---
import '../assets/normalize.css'
import '../assets/style.css'
import '../assets/item.css'
import '../assets/global.css'
import { SEO } from 'astro-seo'
import { getEnv } from '../lib/env'
import { getSingleChannelInfo } from '../lib/telegram'

const { SITE_URL, RSS_URL, RSS_PREFIX } = Astro.locals
const { channel, currentChannel } = Astro.props

const locale = getEnv(import.meta.env, Astro, 'LOCALE') || 'zh-cn'

// 获取所有频道用于左侧导航
const channelsStr = getEnv(import.meta.env, Astro, 'CHANNELS') || getEnv(import.meta.env, Astro, 'CHANNEL')
const channels = channelsStr ? channelsStr.split(',').map(c => c.trim()).filter(Boolean) : []

// 自动获取频道显示名称
const channelNameMap = new Map()
if (channels.length > 1) {
  try {
    const channelInfos = await Promise.all(
      channels.map(async (ch) => {
        try {
          const info = await getSingleChannelInfo(Astro, ch, {})
          return { channel: ch, title: info.title || ch }
        } catch (error) {
          return { channel: ch, title: ch }
        }
      })
    )
    channelInfos.forEach(({ channel: ch, title }) => {
      channelNameMap.set(ch, title)
    })
  } catch (error) {
    channels.forEach(ch => channelNameMap.set(ch, ch))
  }
}

// 备用:从环境变量读取
const channelNamesEnv = getEnv(import.meta.env, Astro, 'CHANNEL_NAMES')
if (channelNamesEnv) {
  channelNamesEnv.split(';').forEach(pair => {
    const [username, displayName] = pair.split(':')
    if (username && displayName) {
      channelNameMap.set(username.trim(), displayName.trim())
    }
  })
}

const seo = channel?.seo
const reqPathname = Astro.url.pathname.replace(/\/$/, '')
const canonical = SITE_URL.startsWith('http') ? new URL(SITE_URL).origin + reqPathname : Astro.url.origin + reqPathname

const { origin, pathname } = new URL(canonical)
const twitter = getEnv(import.meta.env, Astro, 'TWITTER')

const seoParams = {
  title: seo?.title,
  description: seo?.text ?? channel?.description,
  canonical,
  noindex: seo?.noindex ?? getEnv(import.meta.env, Astro, 'NOINDEX'),
  nofollow: seo?.nofollow ?? getEnv(import.meta.env, Astro, 'NOFOLLOW'),
  openGraph: {
    basic: {
      type: 'website',
      title: channel?.title ?? '',
      url: canonical,
      image: channel?.avatar ? channel.avatar : origin + '/favicon.ico',
    },
    optional: {
      description: seo?.text ?? channel?.description,
      locale,
    },
  },
  extend: {
    link: [
      {
        rel: 'icon',
        href: channel?.avatar || '/favicon.svg',
      },
    ],
  },
}

const GOOGLE_SEARCH_SITE = getEnv(import.meta.env, Astro, 'GOOGLE_SEARCH_SITE')
const searchAction = GOOGLE_SEARCH_SITE ? 'https://www.google.com/search' : '/search/result'

const HEADER_INJECT = getEnv(import.meta.env, Astro, 'HEADER_INJECT')
const FOOTER_INJECT = getEnv(import.meta.env, Astro, 'FOOTER_INJECT')
const TAGS = getEnv(import.meta.env, Astro, 'TAGS')
const LINKS = getEnv(import.meta.env, Astro, 'LINKS')
const navs = (getEnv(import.meta.env, Astro, 'NAVS') || '')
  .split(';')
  .filter(Boolean)
  .map((link) => {
    link = link.split(',')
    return {
      title: link[0],
      href: link[1],
    }
  })
---

<!doctype html>
<html lang={locale ?? 'zh-cn'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4f1ec" />
    <link rel="alternate" type="application/rss+xml" title={`${RSS_PREFIX}${channel?.title}`} href={RSS_URL} />
    <style is:inline>
      @view-transition {
        navigation: auto;
      }
    </style>
    <SEO
      titleTemplate={`%s | ${channel?.title}`}
      titleDefault={[channel?.title, seoParams.description].filter(Boolean).join(' - ')}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
  </head>

  <body>
    {/* 移动端汉堡菜单: 在频道页也需要显示 (频道页右侧内容在移动端被折叠到汉堡菜单) */}
    {(navs.length > 0 || TAGS || LINKS || pathname.startsWith('/channel') || channel?.username) && (
      <>
        <button class="mobile-menu-toggle" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="mobile-overlay"></div>
      </>
    )}
    <div id="wrapper">
      {/* 左侧频道列表已移除：主页已提供频道目录，避免重复展示 */}
      <!-- 顶部栏: 将 Home 按钮与搜索框移到页面顶端 (仅在非首页显示，且仅在移动端可见) -->
      {pathname !== '/' && (
        <div class="topbar">
          <div class="topbar-left">
            <a href={SITE_URL} class="topbar-home" title="Home">Home</a>
          </div>
          <div class="topbar-center">
            <form class="topbar-search" action={searchAction} method="get">
              {GOOGLE_SEARCH_SITE ? <input type="hidden" name="as_sitesearch" value={GOOGLE_SEARCH_SITE} /> : null}
              <input type="text" name="q" placeholder="Search..." />
              <button type="submit" aria-label="Search">🔍</button>
            </form>
          </div>
        </div>
      )}

      <div id="container">
        <div id="main-container" class={pathname === '/' ? 'home-main' : ''}>
          <slot />
        </div>
        {pathname !== '/' && (
          <div id="aside-container">
            <slot name="aside">
            <div class="nav">
              <div class="nav-item">
                <a href={SITE_URL} title={channel?.title} class={`nav-link ${pathname === '/' ? 'current' : ''}`}>
                  Home
                </a>
              </div>
              {
                TAGS ? (
                  <div class="nav-item">
                    <a
                      href={`${SITE_URL}tags`}
                      title="Tags"
                      class={`nav-link ${pathname === '/tags' ? 'current' : ''}`}
                    >
                      Tags
                    </a>
                  </div>
                ) : null
              }
              {
                LINKS ? (
                  <div class="nav-item">
                    <a
                      href={`${SITE_URL}links`}
                      title="Links"
                      class={`nav-link ${pathname === '/links' ? 'current' : ''}`}
                    >
                      Links
                    </a>
                  </div>
                ) : null
              }
              {
                navs.map((nav) => (
                  <div class="nav-item">
                    <a href={nav.href} title={nav.title} target="_blank" rel="noopener" class="nav-link">
                      {nav.title}
                    </a>
                  </div>
                ))
              }
            </div>
            <input class="search-icon" name="icon" type="checkbox" placeholder="Search" />
            <form class="search-form" action={searchAction} method="get">
              {GOOGLE_SEARCH_SITE ? <input type="hidden" name="as_sitesearch" value={GOOGLE_SEARCH_SITE} /> : null}
              <input type="text" name="q" placeholder="Search" />
            </form>
            {/* 频道页面保留侧栏内的 Powered by 信息 (放在搜索下方) */}
            {(pathname.startsWith('/channel') || channel?.username) && (
              <div class="sidebar-copyright">
                Powered by
                <a href="https://github.com/banlanzs/MultiChannelBroadCast" target="_blank" rel="noopener">
                  Multi-Channel Fork
                </a>
                <br />
                <a href="https://github.com/ccbikai/BroadcastChannel" target="_blank" rel="noopener">
                  based on BroadcastChannel
                </a>
              </div>
            )}
          </slot>
          </div>
        )}
      </div>
    </div>
    
    {/* Mobile menu (用于汉堡菜单收纳 NAVS/TAGS/LINKS 等) */}
    <aside class="mobile-menu" aria-hidden="true">
      <div class="mobile-menu-inner">
        <div class="mobile-menu-section">
          {TAGS ? (
            <a href={`${SITE_URL}tags`} class="mobile-menu-link">Tags</a>
          ) : null}
          {LINKS ? (
            <a href={`${SITE_URL}links`} class="mobile-menu-link">Links</a>
          ) : null}
          {navs.map((nav) => (
            <a href={nav.href} target="_blank" rel="noopener" class="mobile-menu-link">{nav.title}</a>
          ))}
          {/* 在移动端菜单底部显示 Powered by 信息 (频道页需要此项) */}
          {(pathname.startsWith('/channel') || channel?.username || navs.length > 0 || TAGS || LINKS) && (
            <div class="mobile-menu-powered">
              <hr />
              <div>Powered by <a href="https://github.com/banlanzs/MultiChannelBroadCast" target="_blank" rel="noopener">Multi-Channel Fork</a></div>
              <div>based on <a href="https://github.com/ccbikai/BroadcastChannel" target="_blank" rel="noopener">BroadcastChannel</a></div>
            </div>
          )}
        </div>
      </div>
    </aside>
    <a href="#wrapper" id="back-to-top" aria-label="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg>
    </a>
    <Fragment set:html={FOOTER_INJECT} />
    {/* 仅在首页显示全局页脚 */}
    {pathname === '/' && (
      <footer class="site-footer">
        <div class="site-footer-inner">
          <div>Powered by <a href="https://github.com/banlanzs/MultiChannelBroadCast" target="_blank" rel="noopener">Multi-Channel Fork</a></div>
          <div>based on <a href="https://github.com/ccbikai/BroadcastChannel" target="_blank" rel="noopener">BroadcastChannel</a></div>
          <div>&copy; {new Date().getFullYear()}</div>
        </div>
      </footer>
    )}
  </body>
</html>

<style>
  /* Topbar: Home 按钮和搜索框 - 默认仅用于移动端，桌面端隐藏以避免重复 */
  .topbar {
    display: none; /* 桌面默认隐藏 */
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 20px;
    background: transparent;
  }

  .topbar-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .topbar-home {
    text-decoration: none;
    color: var(--text-color, #333);
    padding: 6px 10px;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .topbar-home:hover { background: var(--hover-background, #f5f5f5) }

  .topbar-search {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .topbar-search input[type="text"] {
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    outline: none;
  }

  .topbar-search button { background: transparent; border: none; cursor: pointer }

  .channel-sidebar {
    flex: 0 0 33.333%;
    width: 33.333%;
    background: var(--background-color, #fff);
    border-right: 1px solid var(--border-color, #e0e0e0);
    overflow-y: auto;
    height: 100vh;
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
  }

  .channel-sidebar-header {
    padding: 20px 16px 12px;
    border-bottom: 1px solid var(--border-color, #e0e0e0);
  }

  .channel-sidebar-header h3 {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--secondary-color, #666);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .channel-sidebar-nav {
    padding: 8px;
  }

  /* 右侧导航区域 */
  .channel-sidebar-section {
    padding: 16px;
    border-top: 1px solid var(--border-color, #e0e0e0);
  }

  .channel-sidebar-section-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--secondary-color, #666);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 12px 0;
  }

  .sidebar-nav-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-nav-link {
    display: block;
    padding: 8px 10px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-color, #333);
    background: transparent;
    transition: all 0.2s;
    font-size: 13px;
  }

  .sidebar-nav-link:hover {
    background: var(--hover-background, #f5f5f5);
    text-decoration: none;
  }

  .sidebar-nav-link.current {
    background: var(--highlight-color, #ff6b6b);
    color: white;
    font-weight: 500;
  }

  .sidebar-search-form {
    margin-top: 8px;
  }

  .sidebar-search-form input[type="text"] {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid var(--border-color, #e0e0e0);
    border-radius: 6px;
    font-size: 13px;
    box-sizing: border-box;
    outline: none;
    transition: border-color 0.2s;
  }

  .sidebar-search-form input[type="text"]:focus {
    border-color: var(--highlight-color, #ff6b6b);
  }

  .sidebar-copyright {
    padding: 16px;
    border-top: 1px solid var(--border-color, #e0e0e0);
    font-size: 11px;
    color: var(--secondary-color, #999);
    line-height: 1.6;
  }

  .sidebar-copyright a {
    color: var(--secondary-color, #999);
    text-decoration: none;
  }

  .sidebar-copyright a:hover {
    color: var(--highlight-color, #ff6b6b);
    text-decoration: underline;
  }

  /* 在桌面端隐藏侧边栏中的导航和搜索 */
  @media (min-width: 1025px) {
    /* 在桌面端隐藏侧边栏中的可折叠区块，但保留版权信息显示在侧栏 */
    .channel-sidebar-section {
      display: none;
    }
  }

  .channel-sidebar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    margin-bottom: 3px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-color, #333);
    background: transparent;
    transition: all 0.2s;
    font-size: 13px;
    line-height: 1.4;
    white-space: nowrap;
  }

  .channel-sidebar-item:hover {
    background: var(--hover-background, #f5f5f5);
  }

  .channel-sidebar-item.active {
    background: var(--highlight-color, #ff6b6b);
    color: white;
    font-weight: 500;
  }

  .channel-sidebar-item svg {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }

  .channel-sidebar-item span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .channel-sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .channel-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .channel-sidebar::-webkit-scrollbar-thumb {
    background: var(--border-color, #e0e0e0);
    border-radius: 3px;
  }

  .channel-sidebar::-webkit-scrollbar-thumb:hover {
    background: var(--secondary-color, #999);
  }

  /* 移动端汉堡菜单 */
  .mobile-menu-toggle {
    display: none;
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 1001;
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid var(--border-color, #e0e0e0);
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
  }

  .mobile-menu-toggle span {
    width: 20px;
    height: 2px;
    background: var(--text-color, #333);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .mobile-menu-toggle.active span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
  }

  .mobile-overlay.active {
    display: block;
  }

  /* mobile menu aside */
  .mobile-menu {
    position: fixed;
    right: -100%;
    top: 0;
    bottom: 0;
    width: 320px;
    background: var(--background-color, #fff);
    z-index: 1100;
    transition: right 0.25s ease;
    box-shadow: -6px 0 24px rgba(0,0,0,0.08);
    overflow-y: auto;
    padding: 20px;
  }

  .mobile-menu.active {
    right: 0;
  }

  .mobile-menu-link {
    display: block;
    padding: 10px 8px;
    margin-bottom: 8px;
    color: #333;
    text-decoration: none;
    border-radius: 6px;
  }

  .mobile-menu-link:hover { background: var(--hover-background, #f5f5f5) }

  .mobile-menu-powered {
    margin-top: 12px;
    color: var(--secondary-color, #777);
    font-size: 13px;
  }

  .mobile-menu-powered hr {
    border: none;
    border-top: 1px solid var(--border-color, #e0e0e0);
    margin: 10px 0;
  }

  /* 页面底部全局页脚 */
  .site-footer {
    width: 100%;
    background: transparent;
    padding: 20px 0;
    margin-top: 30px;
  }

  .site-footer-inner {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
    color: var(--secondary-color, #666);
    font-size: 13px;
  }

  .site-footer-inner a { color: inherit; text-decoration: underline }

  /* 桌面端首页使主内容居中显示 */
  .home-main {
    max-width: 980px;
    margin: 0 auto;
  }

  @media (max-width: 1024px) {
    /* 移动端显示 topbar */
    .topbar {
      display: flex;
    }
    .mobile-menu-toggle {
      display: flex;
    }

    .channel-sidebar {
      position: fixed;
      left: -100%;
      top: 0;
      z-index: 1000;
      transition: left 0.3s ease;
      box-shadow: 2px 0 8px rgba(0,0,0,0.1);
    }

    .channel-sidebar.active {
      left: 0;
    }
    
    /* 移动端首页不需要侧边栏, 保持主内容边距 */
    .home-main { padding: 10px 20px; }

    .channel-sidebar-header,
    .channel-sidebar-nav {
      max-width: 100%;
    }

    #main-container {
      padding-left: 20px;
    }
  }

  @media (max-width: 600px) {
    .mobile-menu-toggle {
      top: 10px;
      left: 10px;
      width: 36px;
      height: 36px;
    }

    .channel-sidebar {
      width: 85vw;
      max-width: 320px;
    }

    #main-container {
      padding-left: 15px;
      padding-right: 15px;
    }

    /* 移动端隐藏右侧边栏 */
    #aside-container {
      display: none !important;
    }
  }
</style>

<script>
  // 移动端菜单切换
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.mobile-menu-toggle')
    const menu = document.querySelector('.mobile-menu')
    const overlay = document.querySelector('.mobile-overlay')

    if (toggle && menu && overlay) {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('active')
        menu.classList.toggle('active')
        overlay.classList.toggle('active')
      })

      overlay.addEventListener('click', () => {
        toggle.classList.remove('active')
        menu.classList.remove('active')
        overlay.classList.remove('active')
      })

      // 点击链接后关闭菜单
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          toggle.classList.remove('active')
          menu.classList.remove('active')
          overlay.classList.remove('active')
        })
      })
    }
  })
</script>
