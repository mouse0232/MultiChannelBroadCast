---
import '../assets/normalize.css'
import '../assets/style.css'
import '../assets/item.css'
import '../assets/global.css'
import { SEO } from 'astro-seo'
import { getEnv } from '../lib/env'
import { getSingleChannelInfo } from '../lib/telegram'

const { SITE_URL, RSS_URL, RSS_PREFIX } = Astro.locals
const { channel, currentChannel } = Astro.props

const locale = getEnv(import.meta.env, Astro, 'LOCALE') || 'zh-cn'

// 获取所有频道用于左侧导航
const channelsStr = getEnv(import.meta.env, Astro, 'CHANNELS') || getEnv(import.meta.env, Astro, 'CHANNEL')
const channels = channelsStr ? channelsStr.split(',').map(c => c.trim()).filter(Boolean) : []

// 自动获取频道显示名称
const channelNameMap = new Map()
if (channels.length > 1) {
  try {
    const channelInfos = await Promise.all(
      channels.map(async (ch) => {
        try {
          const info = await getSingleChannelInfo(Astro, ch, {})
          return { channel: ch, title: info.title || ch }
        } catch (error) {
          return { channel: ch, title: ch }
        }
      })
    )
    channelInfos.forEach(({ channel: ch, title }) => {
      channelNameMap.set(ch, title)
    })
  } catch (error) {
    channels.forEach(ch => channelNameMap.set(ch, ch))
  }
}

// 备用:从环境变量读取
const channelNamesEnv = getEnv(import.meta.env, Astro, 'CHANNEL_NAMES')
if (channelNamesEnv) {
  channelNamesEnv.split(';').forEach(pair => {
    const [username, displayName] = pair.split(':')
    if (username && displayName) {
      channelNameMap.set(username.trim(), displayName.trim())
    }
  })
}

const seo = channel?.seo
const reqPathname = Astro.url.pathname.replace(/\/$/, '')
const canonical = SITE_URL.startsWith('http') ? new URL(SITE_URL).origin + reqPathname : Astro.url.origin + reqPathname

const { origin, pathname } = new URL(canonical)
const twitter = getEnv(import.meta.env, Astro, 'TWITTER')

const seoParams = {
  title: seo?.title,
  description: seo?.text ?? channel?.description,
  canonical,
  noindex: seo?.noindex ?? getEnv(import.meta.env, Astro, 'NOINDEX'),
  nofollow: seo?.nofollow ?? getEnv(import.meta.env, Astro, 'NOFOLLOW'),
  openGraph: {
    basic: {
      type: 'website',
      title: channel?.title ?? '',
      url: canonical,
      image: channel?.avatar ? channel.avatar : origin + '/favicon.ico',
    },
    optional: {
      description: seo?.text ?? channel?.description,
      locale,
    },
  },
  extend: {
    link: [
      {
        rel: 'icon',
        href: channel?.avatar || '/favicon.svg',
      },
    ],
  },
}

const GOOGLE_SEARCH_SITE = getEnv(import.meta.env, Astro, 'GOOGLE_SEARCH_SITE')
const searchAction = GOOGLE_SEARCH_SITE ? 'https://www.google.com/search' : '/search/result'

const HEADER_INJECT = getEnv(import.meta.env, Astro, 'HEADER_INJECT')
const FOOTER_INJECT = getEnv(import.meta.env, Astro, 'FOOTER_INJECT')
const TAGS = getEnv(import.meta.env, Astro, 'TAGS')
const LINKS = getEnv(import.meta.env, Astro, 'LINKS')
const navs = (getEnv(import.meta.env, Astro, 'NAVS') || '')
  .split(';')
  .filter(Boolean)
  .map((link) => {
    link = link.split(',')
    return {
      title: link[0],
      href: link[1],
    }
  })
---

<!doctype html>
<html lang={locale ?? 'zh-cn'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f4f1ec" />
    <link rel="alternate" type="application/rss+xml" title={`${RSS_PREFIX}${channel?.title}`} href={RSS_URL} />
    <style is:inline>
      @view-transition {
        navigation: auto;
      }
    </style>
    <SEO
      titleTemplate={`%s | ${channel?.title}`}
      titleDefault={[channel?.title, seoParams.description].filter(Boolean).join(' - ')}
      twitter={{
        card: 'summary_large_image',
        creator: twitter ? `@${twitter}` : undefined,
      }}
      {...seoParams}
    />
    <Fragment set:html={HEADER_INJECT} />
  </head>

  <body>
    {channels.length > 1 && (
      <>
        <button class="mobile-menu-toggle" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="mobile-overlay"></div>
      </>
    )}
    <div id="wrapper">
      {channels.length > 1 && (
        <aside class="channel-sidebar">
          <div class="channel-sidebar-header">
            <h3>频道列表</h3>
          </div>
          <nav class="channel-sidebar-nav">
            {channels.map(ch => (
              <a 
                href={`${SITE_URL}channel/${ch}`}
                class={`channel-sidebar-item ${currentChannel === ch ? 'active' : ''}`}
                title={channelNameMap.get(ch) || ch}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                <span>{channelNameMap.get(ch) || ch}</span>
              </a>
            ))}
          </nav>
        </aside>
      )}
      <div id="container">
        <div id="main-container">
          <slot />
        </div>
        <div id="aside-container">
          <slot name="aside">
            <div class="nav">
              <div class="nav-item">
                <a href={`${SITE_URL}channel/${channels[0] || ''}`} title={channel?.title} class={`nav-link ${pathname.startsWith('/channel/') ? 'current' : ''}`}>
                  Home
                </a>
              </div>
              {
                TAGS ? (
                  <div class="nav-item">
                    <a
                      href={`${SITE_URL}tags`}
                      title="Tags"
                      class={`nav-link ${pathname === '/tags' ? 'current' : ''}`}
                    >
                      Tags
                    </a>
                  </div>
                ) : null
              }
              {
                LINKS ? (
                  <div class="nav-item">
                    <a
                      href={`${SITE_URL}links`}
                      title="Links"
                      class={`nav-link ${pathname === '/links' ? 'current' : ''}`}
                    >
                      Links
                    </a>
                  </div>
                ) : null
              }
              {
                navs.map((nav) => (
                  <div class="nav-item">
                    <a href={nav.href} title={nav.title} target="_blank" rel="noopener" class="nav-link">
                      {nav.title}
                    </a>
                  </div>
                ))
              }
            </div>
            <input class="search-icon" name="icon" type="checkbox" placeholder="Search" />
            <form class="search-form" action={searchAction} method="get">
              {GOOGLE_SEARCH_SITE ? <input type="hidden" name="as_sitesearch" value={GOOGLE_SEARCH_SITE} /> : null}
              <input type="text" name="q" placeholder="Search" />
            </form>
            <div class="copyright-wrap">
              Powered by
              <a
                href="https://github.com/banlanzs/MultiChannelBroadCast"
                title="Multi-Channel Fork"
                target="_blank"
                rel="noopener"
              >
              Multi-Channel Fork
              </a>
              <br />
              <a
                href="https://github.com/ccbikai/BroadcastChannel"
                title="BroadcastChannel"
                target="_blank"
                rel="noopener"
              >
                based on BroadcastChannel
            </div>
          </slot>
        </div>
      </div>
    </div>
    <a href="#wrapper" id="back-to-top" aria-label="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg>
    </a>
    <Fragment set:html={FOOTER_INJECT} />
  </body>
</html>

<style>
  .channel-sidebar {
    flex: 0 0 33.333%;
    width: 33.333%;
    background: var(--background-color, #fff);
    border-right: 1px solid var(--border-color, #e0e0e0);
    overflow-y: auto;
    height: 100vh;
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
  }

  .channel-sidebar-header {
    padding: 20px 16px 12px;
    border-bottom: 1px solid var(--border-color, #e0e0e0);
    max-width: 50%;
  }

  .channel-sidebar-header h3 {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--secondary-color, #666);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .channel-sidebar-nav {
    padding: 8px;
    max-width: 50%;
  }

  .channel-sidebar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    margin-bottom: 3px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-color, #333);
    background: transparent;
    transition: all 0.2s;
    font-size: 13px;
    line-height: 1.4;
    white-space: nowrap;
  }

  .channel-sidebar-item:hover {
    background: var(--hover-background, #f5f5f5);
  }

  .channel-sidebar-item.active {
    background: var(--highlight-color, #ff6b6b);
    color: white;
    font-weight: 500;
  }

  .channel-sidebar-item svg {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }

  .channel-sidebar-item span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .channel-sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .channel-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .channel-sidebar::-webkit-scrollbar-thumb {
    background: var(--border-color, #e0e0e0);
    border-radius: 3px;
  }

  .channel-sidebar::-webkit-scrollbar-thumb:hover {
    background: var(--secondary-color, #999);
  }

  /* 移动端汉堡菜单 */
  .mobile-menu-toggle {
    display: none;
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 1001;
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid var(--border-color, #e0e0e0);
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
  }

  .mobile-menu-toggle span {
    width: 20px;
    height: 2px;
    background: var(--text-color, #333);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .mobile-menu-toggle.active span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
  }

  .mobile-overlay.active {
    display: block;
  }

  @media (max-width: 1024px) {
    .mobile-menu-toggle {
      display: flex;
    }

    .channel-sidebar {
      position: fixed;
      left: -100%;
      top: 0;
      z-index: 1000;
      transition: left 0.3s ease;
      box-shadow: 2px 0 8px rgba(0,0,0,0.1);
    }

    .channel-sidebar.active {
      left: 0;
    }

    .channel-sidebar-header,
    .channel-sidebar-nav {
      max-width: 100%;
    }

    #main-container {
      padding-left: 20px;
    }
  }

  @media (max-width: 600px) {
    .mobile-menu-toggle {
      top: 10px;
      left: 10px;
      width: 36px;
      height: 36px;
    }

    .channel-sidebar {
      width: 280px;
      max-width: 80vw;
    }

    #main-container {
      padding-left: 15px;
      padding-right: 15px;
    }
  }
</style>

<script>
  // 移动端菜单切换
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.mobile-menu-toggle')
    const sidebar = document.querySelector('.channel-sidebar')
    const overlay = document.querySelector('.mobile-overlay')

    if (toggle && sidebar && overlay) {
      toggle.addEventListener('click', () => {
        toggle.classList.toggle('active')
        sidebar.classList.toggle('active')
        overlay.classList.toggle('active')
      })

      overlay.addEventListener('click', () => {
        toggle.classList.remove('active')
        sidebar.classList.remove('active')
        overlay.classList.remove('active')
      })

      // 点击链接后关闭菜单
      sidebar.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          toggle.classList.remove('active')
          sidebar.classList.remove('active')
          overlay.classList.remove('active')
        })
      })
    }
  })
</script>
