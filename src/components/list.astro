---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import Item from '../components/item.astro'

const { SITE_URL } = Astro.locals
const { channel, before = true, after = true, isItem = false, currentChannel } = Astro.props
const posts = channel.posts ?? []

// 分页优化: 每页显示20条
const POSTS_PER_PAGE = 20
const displayPosts = posts.slice(0, POSTS_PER_PAGE)

const beforeCursor = displayPosts[displayPosts.length - 1]?.id
const afterCursor = displayPosts[0]?.id
---

<Layout channel={channel} currentChannel={currentChannel} id="main-container">
  <slot name="header">
    <Header channel={channel} />
  </slot>

  {isItem && (
    <div class="back-container">
      {
        (() => {
          const backJs = `try{ const key='channel-scroll-${channel.username}'; const postKey='channel-scroll-post-${channel.username}'; const listKey='channel-list-url-${channel.username}'; const pos=sessionStorage.getItem(key); const postId=sessionStorage.getItem(postKey); const listUrl=sessionStorage.getItem(listKey); if(listUrl){ const base='${SITE_URL.replace(/\/$/, '')}'; if(listUrl.startsWith('/')){ location.href = base + listUrl + (postId ? ('#post-'+postId) : ''); } else { location.href = listUrl + (postId ? ('#post-'+postId) : ''); } } else { try{ var ref = document.referrer || ''; if(ref){ var a = document.createElement('a'); a.href = ref; var sameOrigin = a.hostname === location.hostname; if(sameOrigin && ref.indexOf('/channel/${channel.username}') !== -1){ location.href = ref + (postId ? ('#post-'+postId) : ''); throw 'navigated'; } } }catch(e){} if(pos){ location.href='${SITE_URL}channel/${channel.username}' + (postId ? ('#post-'+postId) : ''); } else { history.back(); } } }catch(e){ history.back(); }`;
          return (<button class="back-button" onclick={backJs}>← 返回</button>)
        })()
      }
    </div>
  )}

  {!isItem && (
    <div class="pages-container pages-top">
      {
        before && beforeCursor > 1 ? (
          currentChannel ? (
            <a href={`${SITE_URL}channel/${currentChannel}/before/${beforeCursor}`} title="更早" class="page">
              ← 更早
            </a>
          ) : (
            <a href={`${SITE_URL}before/${beforeCursor}`} title="更早" class="page">
              ← 更早
            </a>
          )
        ) : (
          <span class="page-placeholder">&nbsp;</span>
        )
      }

      <div class="pages-info"></div>
      {
        after && afterCursor ? (
          currentChannel ? (
            <a href={`${SITE_URL}channel/${currentChannel}/after/${afterCursor}`} title="更新" class="page">
              更新 →
            </a>
          ) : (
            <a href={`${SITE_URL}after/${afterCursor}`} title="更新" class="page">
              更新 →
            </a>
          )
        ) : (
          <span class="page-placeholder">&nbsp;</span>
        )
      }
    </div>
  )}

  <div class="items">
    {displayPosts.map((post) => <Item post={post} isItem={isItem} />)}
  </div>

  {!isItem && (
    <script>
      {`document.addEventListener('DOMContentLoaded', function(){ try{ const key='channel-scroll-${channel.username}'; const postKey='channel-scroll-post-${channel.username}'; const listKey='channel-list-url-${channel.username}'; const pos = sessionStorage.getItem(key); const postId = sessionStorage.getItem(postKey); if(pos || (location.hash && location.hash.startsWith('#post-'))){ setTimeout(function(){ if(location.hash && location.hash.startsWith('#post-')){ const el = document.querySelector(location.hash); if(el) el.scrollIntoView({behavior:'auto', block:'center'}); } else if(pos){ window.scrollTo(0, parseInt(pos)); } try{ sessionStorage.removeItem(key); sessionStorage.removeItem(postKey); sessionStorage.removeItem(listKey);}catch(e){} }, 120); } }catch(e){} });`}
    </script>
  )}
  
  {!isItem && displayPosts.length === 0 && (
    <div class="no-posts">
      <p>暂无内容</p>
    </div>
  )}
  
  {!isItem && posts.length > POSTS_PER_PAGE && (
    <div class="load-more-info">
      <p>显示 {displayPosts.length} / {posts.length} 条内容</p>
    </div>
  )}

  <div class="pages-container">
    {
      before && beforeCursor > 1 ? (
        currentChannel ? (
          <a href={`${SITE_URL}channel/${currentChannel}/before/${beforeCursor}`} title="更早" class="page">
            ← 更早
          </a>
        ) : (
          <a href={`${SITE_URL}before/${beforeCursor}`} title="更早" class="page">
            ← 更早
          </a>
        )
      ) : (
        <span class="page-placeholder">&nbsp;</span>
      )
    }

    <div class="pages-info"></div>
    {
      after && afterCursor ? (
        currentChannel ? (
          <a href={`${SITE_URL}channel/${currentChannel}/after/${afterCursor}`} title="更新" class="page">
            更新 →
          </a>
        ) : (
          <a href={`${SITE_URL}after/${afterCursor}`} title="更新" class="page">
            更新 →
          </a>
        )
      ) : (
        <span class="page-placeholder">&nbsp;</span>
      )
    }
  </div>
</Layout>

<style>
  .no-posts {
    padding: 60px 20px;
    text-align: center;
    color: var(--secondary-color, #999);
  }

  .load-more-info {
    padding: 20px;
    text-align: center;
    color: var(--secondary-color, #666);
    font-size: 14px;
    border-top: 1px solid var(--border-color, #e0e0e0);
  }

  .pages-top {
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--border-color, #e0e0e0);
  }
  .back-container {
    padding: 10px 20px;
  }

  .back-button {
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: white;
    cursor: pointer;
  }
</style>
