---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import Item from '../components/item.astro'

const { SITE_URL } = Astro.locals
const { channel, before = true, after = true, isItem = false, currentChannel } = Astro.props
const posts = channel.posts ?? []

// 分页优化: 每页显示20条
const POSTS_PER_PAGE = 20
const displayPosts = posts.slice(0, POSTS_PER_PAGE)

// 使用 published_at 作为分页 cursor（避免 id 含斜杠导致路由 404）
const beforeCursor = displayPosts[displayPosts.length - 1]?.published_at || displayPosts[displayPosts.length - 1]?.id
const afterCursor = displayPosts[0]?.published_at || displayPosts[0]?.id
---

<Layout channel={channel} currentChannel={currentChannel} id="main-container">
  <slot name="header">
    <Header channel={channel} />
  </slot>

  {isItem && (
    <div class="back-container">
      {
        (() => {
          const backJs = `try{ const key='channel-scroll-${channel.username}'; const postKey='channel-scroll-post-${channel.username}'; const listKey='channel-list-url-${channel.username}'; const pos=sessionStorage.getItem(key); const postId=sessionStorage.getItem(postKey); const listUrl=sessionStorage.getItem(listKey); if(listUrl){ const base='${SITE_URL.replace(/\/$/, '')}'; if(listUrl.startsWith('/')){ location.href = base + listUrl + (postId ? ('#post-'+postId) : ''); } else { location.href = listUrl + (postId ? ('#post-'+postId) : ''); } } else { try{ var ref = document.referrer || ''; if(ref){ var a = document.createElement('a'); a.href = ref; var sameOrigin = a.hostname === location.hostname; if(sameOrigin && ref.indexOf('/channel/${channel.username}') !== -1){ location.href = ref + (postId ? ('#post-'+postId) : ''); throw 'navigated'; } } }catch(e){} if(pos){ location.href='${SITE_URL}channel/${channel.username}' + (postId ? ('#post-'+postId) : ''); } else { history.back(); } } }catch(e){ history.back(); }`;
          return (<button class="back-button" onclick={backJs}>← 返回</button>)
        })()
      }
    </div>
  )}

  {!isItem && (
    <div class="pages-container pages-top">
      {
        after && afterCursor ? (
          currentChannel ? (
            <a href={`${SITE_URL}channel/${currentChannel}/after/${encodeURIComponent(afterCursor)}`} title="更新" class="page">
              更新 →
            </a>
          ) : (
            <a href={`${SITE_URL}after/${encodeURIComponent(afterCursor)}`} title="更新" class="page">
              更新 →
            </a>
          )
        ) : (
          <span class="page-placeholder">&nbsp;</span>
        )
      }

      <div class="pages-info"></div>
      {
        before && beforeCursor ? (
          currentChannel ? (
            <a href={`${SITE_URL}channel/${currentChannel}/before/${encodeURIComponent(beforeCursor)}`} title="更早" class="page">
              ← 更早
            </a>
          ) : (
            <a href={`${SITE_URL}before/${encodeURIComponent(beforeCursor)}`} title="更早" class="page">
              ← 更早
            </a>
          )
        ) : (
          <span class="page-placeholder">&nbsp;</span>
        )
      }
    </div>
  )}

  <div class="items">
    {displayPosts.map((post) => <Item post={post} isItem={isItem} />)}
  </div>

  {!isItem && (
    <script define:vars={{ channelUsername: channel.username }}>
      (function(){ try{ var key='channel-scroll-' + channelUsername; var postKey='channel-scroll-post-' + channelUsername; var listKey='channel-list-url-' + channelUsername;

        // Delegated click handler: 捕获所有点击，若点击到跳转到 /posts/ 的链接，则保存当前列表 URL 与滚动位置
        document.addEventListener('click', function(e){ try{ var a = e.target.closest && e.target.closest('a'); if(!a) return; var href = a.getAttribute('href') || a.href || ''; try{ var u = new URL(href, location.origin); href = u.pathname + u.search + u.hash; }catch(err){} if(href.indexOf('/posts/') !== -1){ try{ sessionStorage.setItem(listKey, location.pathname + location.search); sessionStorage.setItem(key, String(window.scrollY)); var m = href.match(/\/posts\/(\d+)/); if(m) sessionStorage.setItem(postKey, m[1]); }catch(err){} } }catch(err){} }, true);

        // 恢复滚动位置或 hash 指向 (优化版: 避免与返回顶部按钮冲突)
        document.addEventListener('DOMContentLoaded', function(){ try{ var pos = sessionStorage.getItem(key); var postId = sessionStorage.getItem(postKey); var listUrl = sessionStorage.getItem(listKey); if(pos || (location.hash && location.hash.indexOf('#post-')===0)){ setTimeout(function(){ if(location.hash && location.hash.indexOf('#post-')===0){ var el = document.querySelector(location.hash); if(el) {
          // 使用瞬间滚动而非平滑滚动，避免与返回顶部按钮的平滑滚动冲突
          el.scrollIntoView({behavior:'instant', block:'center'});
        } } else if(pos){ window.scrollTo(0, parseInt(pos)); } try{ sessionStorage.removeItem(key); sessionStorage.removeItem(postKey); sessionStorage.removeItem(listKey);}catch(e){} }, 120); } }catch(e){} });

      }catch(e){} })();
    </script>
  )}
  
  {!isItem && displayPosts.length === 0 && (
    <div class="no-posts">
      <p>暂无内容</p>
    </div>
  )}
  
  {!isItem && posts.length > POSTS_PER_PAGE && (
    <div class="load-more-info">
      <p>显示 {displayPosts.length} / {posts.length} 条内容</p>
    </div>
  )}

  <div class="pages-container">
    {
      after && afterCursor ? (
        currentChannel ? (
          <a href={`${SITE_URL}channel/${currentChannel}/after/${encodeURIComponent(afterCursor)}`} title="更新" class="page">
            更新 →
          </a>
        ) : (
          <a href={`${SITE_URL}after/${encodeURIComponent(afterCursor)}`} title="更新" class="page">
            更新 →
          </a>
        )
      ) : (
        <span class="page-placeholder">&nbsp;</span>
      )
    }

    <div class="pages-info"></div>
    {
      before && beforeCursor ? (
        currentChannel ? (
          <a href={`${SITE_URL}channel/${currentChannel}/before/${encodeURIComponent(beforeCursor)}`} title="更早" class="page">
            ← 更早
          </a>
        ) : (
          <a href={`${SITE_URL}before/${encodeURIComponent(beforeCursor)}`} title="更早" class="page">
            ← 更早
          </a>
        )
      ) : (
        <span class="page-placeholder">&nbsp;</span>
      )
    }
  </div>
</Layout>

<style>
  .no-posts {
    padding: 60px 20px;
    text-align: center;
    color: var(--secondary-color, #999);
  }

  .load-more-info {
    padding: 20px;
    text-align: center;
    color: var(--secondary-color, #666);
    font-size: 14px;
    border-top: 1px solid var(--border-color, #e0e0e0);
  }

  .pages-top {
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--border-color, #e0e0e0);
  }
  .back-container {
    padding: 10px 20px;
  }

  .back-button {
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: white;
    cursor: pointer;
  }
</style>
