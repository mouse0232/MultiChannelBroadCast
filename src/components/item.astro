---
import dayjs from '../lib/dayjs'
import { getEnv } from '../lib/env'

const { post, isItem = false } = Astro.props
const { SITE_URL } = Astro.locals

const locale = getEnv(import.meta.env, Astro, 'LOCALE') || 'en'
const timezone = getEnv(import.meta.env, Astro, 'TIMEZONE') || 'UTC'

dayjs.locale(locale)
dayjs.tz.setDefault(timezone)

const datetime = dayjs(post.datetime)
const url = `${SITE_URL}posts/${post.id}`

// 读取评论配置 - 支持多种格式
const commentsEnabled = getEnv(import.meta.env, Astro, 'COMMENTS')
const showComments = commentsEnabled === 'true' || commentsEnabled === true

// 调试信息(仅开发环境)
if (import.meta.env.DEV && isItem) {
  console.log('Comments config:', { commentsEnabled, showComments, isItem, hasChannel: !!post.channel })
}
---

<div class="item" id={`post-${post.id}`}>
  <div class="time-box">
    <div class="dot"></div>
    <div class="time">
      {
        // 在点击跳转到单帖时, 保存当前频道的滚动位置以便回退时恢复
      }
      {
        (() => {
          const onclickSave = post.channel ? `try{ sessionStorage.setItem('channel-scroll-${post.channel}', String(window.scrollY)); sessionStorage.setItem('channel-scroll-post-${post.channel}', '${post.id}'); sessionStorage.setItem('channel-list-url-${post.channel}', location.pathname + location.search); }catch(e){} ` : null
          return (
            <a href={url} class="item-link" onclick={onclickSave}>
              <time datetime={post.datetime} title={post.datetime}>
                {isItem ? datetime.format('LLLL') : datetime.fromNow()}
              </time>
            </a>
          )
        })()
      }
    </div>
  </div>

  {post.content && (
    <div class="text-box content" set:html={post.content} />
  )}

  {post.tags && post.tags.length > 0 && (
    <div class="tag-box">
      {post.tags.map((tag) => (
        <a href={`${SITE_URL}search/${encodeURIComponent(`#${tag}`)}`} class="tag">
          #{tag}
        </a>
      ))}
    </div>
  )}

  {/* 显示频道来源 - 多频道特有 */}
  {post.channel && (
    <div class="channel-source">
      <small>
        来自频道: <a href={`https://t.me/${post.channel}`} target="_blank" rel="noopener">@{post.channel}</a>
      </small>
    </div>
  )}

  {/* 消息操作按钮 */}
  <div class="message-actions">
    <button
      class="action-btn copy-btn"
      data-post-id={post.id}
      title="复制消息内容（Markdown格式）"
      aria-label="复制消息内容"
    >
      <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      <span class="action-text">复制</span>
    </button>

    <button
      class="action-btn share-btn"
      data-post-url={url}
      title="复制分享链接"
      aria-label="获取分享链接"
    >
      <svg class="action-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
        <polyline points="16,6 12,2 8,6"/>
        <line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
      <span class="action-text">分享</span>
    </button>
  </div>

  {/* 反馈提示 */}
  <div class="action-feedback" id={`feedback-${post.id}`} role="status" aria-live="polite"></div>

  {/* Telegram 评论区 */}
  {showComments && isItem && post.channel && (
    <div class="comments">
      <div id="telegram-comments-loading" class="comments-loading" aria-live="polite">
        <div class="spinner" aria-hidden="true"></div>
        <span>Loading comments...</span>
      </div>
      <div id="telegram-comments-placeholder" style="display: none; padding: 20px; background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; margin-bottom: 20px;">
        <p style="margin: 0; color: #856404;">
          ⚠️ <strong>评论区加载失败</strong><br/>
          可能原因:
          <ul style="margin: 10px 0; padding-left: 20px;">
            <li>浏览器广告拦截器阻止了 Telegram widget</li>
            <li>网络连接问题</li>
          </ul>
          <strong>解决方法:</strong>
          <ol style="margin: 10px 0; padding-left: 20px;">
            <li>临时禁用广告拦截器(如 AdBlock、uBlock Origin)</li>
            <li>或将本站添加到广告拦截器的白名单</li>
            <li>或直接访问 <a href={`https://t.me/${post.channel}/${post.id}`} target="_blank" rel="noopener" style="color: #007bff;">Telegram 查看评论</a></li>
          </ol>
        </p>
      </div>
      <div id="telegram-comments-container"></div>
      <script is:inline define:vars={{ channel: post.channel, id: post.id }}>
        (function() {
          const container = document.getElementById('telegram-comments-container');
          const placeholder = document.getElementById('telegram-comments-placeholder');
          const loading = document.getElementById('telegram-comments-loading');

          const hideLoading = () => { if (loading) loading.style.display = 'none'; };

          // 创建 script 元素
          const script = document.createElement('script');
          script.async = true;
          script.src = 'https://telegram.org/js/telegram-widget.js';
          script.setAttribute('data-telegram-discussion', `${channel}/${id}`);
          script.setAttribute('data-comments-limit', '50');
          script.setAttribute('data-colorful', '1');
          script.setAttribute('data-color', '454545');

          // 监听加载错误
          script.onerror = function() {
            hideLoading();
            if (placeholder) {
              placeholder.style.display = 'block';
            }
          };

          // 检测 widget 是否成功加载
          script.onload = function() {
            // 5秒后检查是否有 iframe 生成
            setTimeout(function() {
              const iframe = container.querySelector('iframe');
              hideLoading();
              if (!iframe && placeholder) {
                placeholder.style.display = 'block';
              }
            }, 5000);
          };

          // 兜底：最长 8s 后隐藏 loading
          setTimeout(hideLoading, 8000);

          container.appendChild(script);
        })();
      </script>
    </div>
  )}
</div>

<script is:inline define:vars={{
  postId: post.id,
  postChannel: post.channel,
  postUrl: url
}}>
(function() {
  // HTML到Markdown转换器
  function htmlToMarkdown(html) {
    if (!html) return '';
    const temp = document.createElement('div');
    temp.innerHTML = html;

    // ============ 阶段1: 清理不需要的内容 ============

    // 移除所有emoji元素（i.emoji 和包含emoji的b标签）
    temp.querySelectorAll('i.emoji').forEach(emoji => emoji.remove());
    temp.querySelectorAll('b').forEach(b => {
      const text = b.textContent;
      if (/[\u{1F300}-\u{1F9FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]|🍀|📱|🔥|⚡|🎯|📊|💎|🚀|⭐|🎉|🎊|🎈|🎁|🏆|🥇|🥈|🥉|🏅|🎖️|🏵️|🎗️|🎫|🎟️|🎪|🎭|🎨|🎬|🎤|🎧|🎼|🎵|🎶|🎹|🥁|🎷|🎺|🎸|🪕|🎻|📮|🍵|🍀/u.test(text)) {
        b.remove();
      }
    });

    // 移除所有t.me链接
    temp.querySelectorAll('a[href*="t.me"]').forEach(link => {
      link.remove();
    });

    // 处理引用回复 - 移除外层链接，保留blockquote，但将内部链接转为纯文本
    temp.querySelectorAll('.tgme_widget_message_reply').forEach(reply => {
      const blockquote = reply.querySelector('blockquote');
      if (blockquote) {
        // 移除作者信息
        blockquote.querySelectorAll('.tgme_widget_message_author').forEach(author => author.remove());

        // 将blockquote内的所有链接转换为纯文本
        blockquote.querySelectorAll('a').forEach(link => {
          link.outerHTML = link.textContent;
        });

        // 清理回复文本中的频道标识
        const replyText = blockquote.querySelector('.tgme_widget_message_text');
        if (replyText) {
          let text = replyText.innerHTML;
          // 移除频道相关文本
          text = text.replace(/\s*(🍀|📮|🍵)?\s*(在花频道|茶馆聊天|投稿)\s*/g, '');
          text = text.replace(/\s*环球市场播报\s*/g, '');
          replyText.innerHTML = text.trim();
        }

        // 用blockquote替换整个reply元素
        reply.outerHTML = blockquote.outerHTML;
      } else {
        reply.remove();
      }
    });

    // 清理引用框内的作者信息（如果还有残留）
    temp.querySelectorAll('.tgme_widget_message_author').forEach(author => author.remove());

    // 清理回复文本中的频道标识（如果还有残留）
    temp.querySelectorAll('.tgme_widget_message_text').forEach(replyText => {
      let text = replyText.innerHTML;
      // 移除频道相关文本
      text = text.replace(/\s*(🍀|📮|🍵)?\s*(在花频道|茶馆聊天|投稿)\s*/g, '');
      text = text.replace(/\s*环球市场播报\s*/g, '');
      replyText.innerHTML = text.trim();
    });

    // 移除包含频道信息的small元素
    temp.querySelectorAll('small').forEach(small => {
      const text = small.textContent;
      if (text.includes('频道') || text.includes('channel') ||
          text.includes('在花') || text.includes('茶馆') ||
          text.includes('投稿')) {
        small.remove();
      }
    });

    // 清理空的blockquote
    temp.querySelectorAll('blockquote').forEach(quote => {
      if (!quote.textContent.trim()) {
        quote.remove();
      }
    });

    // 处理重复的图片 - 移除可能的重复图片元素
    const processedImages = new Set();
    temp.querySelectorAll('img').forEach(img => {
      const src = img.src;
      const alt = img.alt || '';
      const key = `${src}-${alt}`;

      if (processedImages.has(key)) {
        // 如果已经处理过相同的图片，移除重复的
        img.remove();
      } else {
        processedImages.add(key);
      }
    });

    // 清理包含emoji的文本节点
    const walker = document.createTreeWalker(
      temp,
      NodeFilter.SHOW_TEXT,
      null,
      false
    );

    const textNodes = [];
    let node;
    while (node = walker.nextNode()) {
      textNodes.push(node);
    }

    textNodes.forEach(textNode => {
      const text = textNode.textContent;
      // 移除只包含emoji和空白的文本节点
      if (/^\s*[\u{1F300}-\u{1F9FF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}🍀📮🍵🎗]*\s*$/u.test(text)) {
        textNode.remove();
      } else {
        // 清理文本中的emoji字符
        const cleanText = text.replace(/[\u{1F300}-\u{1F9FF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}🍀📮🍵🎗]/gu, '');
        if (cleanText !== text) {
          textNode.textContent = cleanText;
        }
      }
    });

    // ============ 阶段2: 转换为Markdown ============

    // 递归转换节点为Markdown
    function nodeToMarkdown(node, inList = false) {
      if (node.nodeType === Node.TEXT_NODE) {
        return node.textContent;
      }

      if (node.nodeType !== Node.ELEMENT_NODE) {
        return '';
      }

      const tag = node.tagName.toLowerCase();

      // 处理各种元素类型
      switch (tag) {
        // 标题
        case 'h1':
        case 'h2':
        case 'h3':
        case 'h4':
        case 'h5':
        case 'h6': {
          const level = parseInt(tag[1]);
          const prefix = '#'.repeat(level) + ' ';
          const content = processInlineNodes(node).trim();
          return prefix + content + '\n\n';
        }

        // 段落
        case 'p': {
          const content = processInlineNodes(node).trim();
          if (!content) return '';
          return content + '\n\n';
        }

        // 粗体
        case 'strong':
        case 'b': {
          return '**' + processInlineNodes(node) + '**';
        }

        // 斜体
        case 'em':
        case 'i': {
          return '*' + processInlineNodes(node) + '*';
        }

        // 链接
        case 'a': {
          const href = node.getAttribute('href') || '';
          const text = processInlineNodes(node).trim();
          if (!href) return text;
          return '[' + text + '](' + href + ')';
        }

        // 图片
        case 'img': {
          const src = node.getAttribute('src') || '';
          const alt = node.getAttribute('alt') || '';
          if (!src) return '';
          return '![' + alt + '](' + src + ')';
        }

        // 代码
        case 'code': {
          // 检查是否在pre中（代码块）
          if (node.parentNode && node.parentNode.tagName.toLowerCase() === 'pre') {
            return node.textContent;
          }
          // 行内代码
          return '`' + node.textContent + '`';
        }

        // 代码块
        case 'pre': {
          const code = node.textContent;
          return '```\n' + code + '\n```\n\n';
        }

        // 无序列表
        case 'ul': {
          const items = Array.from(node.children).filter(li => li.tagName.toLowerCase() === 'li');
          let result = '';
          items.forEach(li => {
            result += '- ' + processInlineNodes(li).trim() + '\n';
          });
          return result + '\n';
        }

        // 有序列表
        case 'ol': {
          const items = Array.from(node.children).filter(li => li.tagName.toLowerCase() === 'li');
          let result = '';
          items.forEach((li, index) => {
            result += (index + 1) + '. ' + processInlineNodes(li).trim() + '\n';
          });
          return result + '\n';
        }

        // 列表项
        case 'li': {
          return processInlineNodes(node).trim();
        }

        // 引用
        case 'blockquote': {
          const content = processInlineNodes(node).trim();
          // 按行处理，每行加引用前缀
          const lines = content.split('\n');
          return lines.map(line => '> ' + line).join('\n') + '\n\n';
        }

        // 分隔线
        case 'hr': {
          return '---\n\n';
        }

        // 换行
        case 'br': {
          return '\n';
        }

        // 表格 - 保留HTML（Discourse支持）
        case 'table':
        case 'thead':
        case 'tbody':
        case 'tr':
        case 'td':
        case 'th': {
          // 简单处理：提取表格HTML，清理多余空白
          const html = node.outerHTML
            .replace(/\s+</g, '<')
            .replace(/>\s+/g, '>')
            .replace(/\n\s*/g, '');
          return html + '\n\n';
        }

        // div/span等容器 - 递归处理子节点
        case 'div':
        case 'span': {
          return processInlineNodes(node);
        }

        // 默认：处理子节点
        default: {
          return processInlineNodes(node);
        }
      }
    }

    // 处理内联节点
    function processInlineNodes(node) {
      let result = '';
      for (const child of node.childNodes) {
        result += nodeToMarkdown(child);
      }
      return result;
    }

    // 开始转换
    let markdown = '';

    // 处理所有顶层子节点
    for (const child of temp.childNodes) {
      markdown += nodeToMarkdown(child);
    }

    // 清理多余空行
    markdown = markdown
      .replace(/\n{3,}/g, '\n\n')  // 最多两个连续换行
      .replace(/^\n+/, '')           // 移除开头的换行
      .replace(/\n+$/, '')           // 移除结尾的换行
      .trim();

    return markdown;
  }

  // 剪贴板复制（带降级方案）
  async function copyToClipboard(text) {
    try {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
        return true;
      } else {
        // 降级到 execCommand
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-9999px';
        document.body.appendChild(textArea);
        textArea.select();
        const result = document.execCommand('copy');
        document.body.removeChild(textArea);
        return result;
      }
    } catch (err) {
      console.error('复制失败:', err);
      return false;
    }
  }

  // 显示用户反馈
  function showFeedback(message, isError = false) {
    const feedback = document.getElementById(`feedback-${postId}`);
    if (!feedback) return;

    feedback.textContent = message;
    feedback.className = `action-feedback ${isError ? 'error' : 'success'}`;
    feedback.style.display = 'block';

    setTimeout(() => {
      feedback.style.display = 'none';
    }, 3000);
  }

  // 复制按钮处理
  async function handleCopy() {
    try {
      const contentEl = document.querySelector(`#post-${postId} .content`);
      if (!contentEl) {
        showFeedback('未找到消息内容', true);
        return;
      }

      const markdownContent = htmlToMarkdown(contentEl.innerHTML);
      let copyText = markdownContent;

      if (postChannel) {
        copyText += `\n\n来源: https://t.me/${postChannel}`;
      }

      const success = await copyToClipboard(copyText);
      showFeedback(success ? '✓ 已复制到剪贴板' : '✗ 复制失败', !success);
    } catch (err) {
      console.error('复制错误:', err);
      showFeedback('✗ 复制失败', true);
    }
  }

  // 分享按钮处理
  async function handleShare(e) {
    try {
      const telegramUrl = postChannel ? `https://t.me/${postChannel}/${postId}` : '';

      if (telegramUrl && e.shiftKey) {
        // Shift+点击 = Telegram 链接
        const success = await copyToClipboard(telegramUrl);
        showFeedback(success ? '✓ Telegram链接已复制' : '✗ 复制失败', !success);
      } else {
        // 普通点击 = 网站链接
        const success = await copyToClipboard(postUrl);
        showFeedback(success ? '✓ 网站链接已复制' : '✗ 复制失败', !success);
      }
    } catch (err) {
      console.error('分享错误:', err);
      showFeedback('✗ 分享失败', true);
    }
  }

  // 事件绑定（使用事件委托）
  document.addEventListener('click', function(e) {
    const copyBtn = e.target.closest(`#post-${postId} .copy-btn`);
    const shareBtn = e.target.closest(`#post-${postId} .share-btn`);

    if (copyBtn) {
      e.preventDefault();
      handleCopy();
    } else if (shareBtn) {
      e.preventDefault();
      handleShare(e);
    }
  });
})();
</script>

<style>
  .channel-source {
    margin-top: 10px;
    padding: 8px 12px;
    background-color: var(--background-color, #f5f5f5);
    border-radius: 4px;
    font-size: 13px;
    color: var(--secondary-color, #666);
  }

  .channel-source a {
    color: var(--highlight-color, #ff6b6b);
    text-decoration: none;
  }

  .channel-source a:hover {
    text-decoration: underline;
  }

  .message-actions {
    margin-top: 10px;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
  }

  .action-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    background: transparent;
    border: 1px solid var(--border-color, rgba(0, 0, 0, 0.05));
    border-radius: 4px;
    color: var(--secondary-color, #666);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    outline: none;
  }

  .action-btn:hover {
    background: var(--hover-background, #f5f5f5);
    border-color: var(--highlight-color, #ff6b6b);
    color: var(--highlight-color, #ff6b6b);
  }

  .action-btn:active {
    transform: translateY(1px);
  }

  .action-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .action-text {
    font-weight: 500;
  }

  .action-feedback {
    display: none;
    margin-top: 6px;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    animation: fadeInSlide 0.3s ease;
  }

  .action-feedback.success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .action-feedback.error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  @keyframes fadeInSlide {
    from {
      opacity: 0;
      transform: translateY(-5px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .message-actions {
      gap: 6px;
    }

    .action-btn {
      padding: 5px 10px;
      font-size: 12px;
    }

    .action-text {
      display: none; /* 移动端只显示图标 */
    }

    .action-icon {
      width: 16px;
      height: 16px;
    }
  }

  @media (max-width: 480px) {
    .message-actions {
      justify-content: flex-start;
    }

    .action-btn {
      min-width: 36px;
      justify-content: center;
      padding: 6px;
    }
  }

  .comments {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border-color, #e0e0e0);
  }
  .comments-loading {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid var(--border-color, #e0e0e0);
    border-radius: 8px;
    color: var(--secondary-color, #666);
    font-size: 14px;
