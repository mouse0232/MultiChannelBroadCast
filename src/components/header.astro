---
import { getEnv } from '../lib/env'

const { SITE_URL } = Astro.locals
const { channel, showGlobalRss = false, rssUrl } = Astro.props

const telegram = getEnv(import.meta.env, Astro, 'TELEGRAM')
const twitter = getEnv(import.meta.env, Astro, 'TWITTER')
const github = getEnv(import.meta.env, Astro, 'GITHUB')
const mastodon = getEnv(import.meta.env, Astro, 'MASTODON')
const bluesky = getEnv(import.meta.env, Astro, 'BLUESKY')
const discord = getEnv(import.meta.env, Astro, 'DISCORD')
const podcast = getEnv(import.meta.env, Astro, 'PODCAST')
const rssHref = rssUrl || (channel?.username ? `${SITE_URL}channel/${channel.username}/rss.xml` : `${SITE_URL}rss.xml`)
const showRss = showGlobalRss || Boolean(channel?.username)

// 自定义站点图标,优先级: SITE_AVATAR > channel.avatar
const siteAvatar = getEnv(import.meta.env, Astro, 'SITE_AVATAR')
const avatarUrl = siteAvatar || channel?.avatar

// 确定链接目标:如果有频道用户名,链接到频道页面;否则链接到首页
// Allow overriding destination; if href is explicitly false, render as plain text
const channelUrl = channel?.href === false ? null : (channel?.href || (channel?.username ? `${SITE_URL}channel/${channel.username}` : SITE_URL))
---

<div id="header">
  {avatarUrl && (
    <a href={channelUrl}>
      <img
        src={avatarUrl}
        alt={channel?.title || 'Site Avatar'}
        class="header-avatar"
        referrerpolicy="no-referrer"
        onerror={channel?.avatarFallback ? `this.onerror=null;this.src='${channel.avatarFallback}'` : undefined}
      />
    </a>
  )}
  <div class="header-title">
    {channelUrl ? (
      <a href={channelUrl} class="site-title" title={channel?.title}>
        {channel?.title}
      </a>
    ) : (
      <span class="site-title" title={channel?.title}>
        {channel?.title}
      </span>
    )}
  </div>
  <div class="header-icons">
    {telegram && (
      <a href={`https://t.me/${telegram}`} target="_blank" rel="noopener" title="Telegram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg>
      </a>
    )}
    {twitter && (
      <a href={`https://twitter.com/${twitter}`} target="_blank" rel="noopener" title="Twitter">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
      </a>
    )}
    {github && (
      <a href={`https://github.com/${github}`} target="_blank" rel="noopener" title="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
      </a>
    )}
    {showRss && (
      <a href={rssHref} target="_blank" rel="alternate noopener" title="RSS">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
      </a>
    )}
    {mastodon && (
      <a href={mastodon} target="_blank" rel="noopener me" title="Mastodon">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.327 8.566c0-4.339-2.843-5.61-2.843-5.61-1.433-.658-3.894-.935-6.451-.956h-.063c-2.557.021-5.016.298-6.45.956 0 0-2.843 1.272-2.843 5.61 0 .993-.019 2.181.012 3.441.103 4.243.778 8.425 4.701 9.463 1.809.479 3.362.579 4.612.51 2.268-.126 3.541-.809 3.541-.809l-.075-1.646s-1.621.511-3.441.449c-1.804-.062-3.707-.194-3.999-2.409a4.523 4.523 0 0 1-.04-.621s1.77.433 4.014.536c1.372.063 2.658-.08 3.965-.236 2.506-.299 4.688-1.843 4.962-3.254.434-2.223.398-5.424.398-5.424zm-3.353 5.59h-2.081V9.057c0-1.075-.452-1.62-1.357-1.62-1 0-1.501.647-1.501 1.927v2.791h-2.069V9.364c0-1.28-.501-1.927-1.502-1.927-.905 0-1.357.546-1.357 1.62v5.099H6.026V8.903c0-1.074.273-1.927.823-2.558.566-.631 1.307-.955 2.228-.955 1.065 0 1.872.409 2.405 1.228l.518.869.519-.869c.533-.819 1.34-1.228 2.405-1.228.92 0 1.662.324 2.228.955.549.631.822 1.484.822 2.558v5.253z"></path></svg>
      </a>
    )}
    {bluesky && (
      <a href={bluesky} target="_blank" rel="noopener" title="Bluesky">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10a6 6 0 0 0-6-6v12a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a6 6 0 0 0-6 6Z"></path><circle cx="12" cy="17" r="3"></circle></svg>
      </a>
    )}
    {discord && (
      <a href={discord} target="_blank" rel="noopener" title="Discord">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"></circle><circle cx="15" cy="12" r="1"></circle><path d="M7.5 7.5c3.5-1 6.5-1 10 0"></path><path d="M7 16.5c3.5 1 6.5 1 10 0"></path><path d="M15.5 17c0 1 1.5 3 2 3 1.5 0 2.833-1.667 3.5-3 .667-1.667.5-5.833-1.5-11.5-1-2.833-2.5-3.5-3.5-3.5-.5 0-2 0-3.5.5l-.5.5"></path><path d="M8.5 17c0 1-1.356 3-1.832 3-1.429 0-2.698-1.667-3.333-3-.635-1.667-.476-5.833 1.428-11.5C5.714 2.667 7.143 2 8.143 2c.476 0 1.904 0 3.333.5l.476.5"></path></svg>
      </a>
    )}
    {podcast && (
      <a href={podcast} target="_blank" rel="noopener" title="Podcast">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" x2="12" y1="19" y2="22"></line></svg>
      </a>
    )}
  </div>
</div>

<style>
  #header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 20px;
    gap: 15px;
  }

  .header-avatar {
    width: 128px;
    height: 128px;
    border-radius: 50%;
    object-fit: cover;
  }

  .header-title {
    text-align: center;
  }

  .site-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-color, #333);
    text-decoration: none;
  }

  .site-title:hover {
    text-decoration: underline;
  }

  .header-icons {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .header-icons a {
    color: var(--secondary-color, #666);
    transition: color 0.2s;
  }

  .header-icons a:hover {
    color: var(--highlight-color, #ff6b6b);
  }
</style>
