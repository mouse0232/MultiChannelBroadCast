---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import { getEnv } from '../lib/env'
import sanitizeHtml from 'sanitize-html'

const { SITE_NAME, SITE_AVATAR, SITE_URL } = Astro.locals

const channel = {
  title: SITE_NAME || 'About',
  avatar: SITE_AVATAR || null,
  href: `${SITE_URL}about`,
  seo: {
    title: 'About',
    text: 'About page placeholder',
  },
}

// Placeholder text; replace with your real About content.
const placeholder = getEnv(import.meta.env, Astro, 'ABOUT_PLACEHOLDER') || 'to be fill'

const isLikelyHtml = /<[^>]+>/.test(placeholder)

function simpleMarkdownToHtml(md = '') {
  // escape HTML to keep Markdown safe before converting
  let text = md.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')

  // headings
  text = text.replace(/^###### (.*)$/gm, '<h6>$1</h6>')
    .replace(/^##### (.*)$/gm, '<h5>$1</h5>')
    .replace(/^#### (.*)$/gm, '<h4>$1</h4>')
    .replace(/^### (.*)$/gm, '<h3>$1</h3>')
    .replace(/^## (.*)$/gm, '<h2>$1</h2>')
    .replace(/^# (.*)$/gm, '<h1>$1</h1>')

  // lists (simple bullet list support)
  text = text.replace(/(^|\n)([-*]) (.*(?:\n[-*] .*)*)/g, (_match, prefix, _bullet, body) => {
    const items = body.split('\n').map(line => line.replace(/^[-*]\s*/, '').trim()).filter(Boolean)
    return `${prefix}<ul>${items.map(item => `<li>${item}</li>`).join('')}</ul>`
  })

  // inline styles
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')

  // paragraphs
  const segments = text.split(/\n{2,}/).map(seg => {
    const trimmed = seg.trim()
    if (!trimmed) return ''
    if (/^<\s*(h\d|ul|ol|pre|blockquote)/i.test(trimmed)) {
      return trimmed
    }
    return `<p>${trimmed.replace(/\n/g, '<br />')}</p>`
  }).filter(Boolean)

  return segments.join('\n')
}

const contentHtml = sanitizeHtml(
  isLikelyHtml ? placeholder : simpleMarkdownToHtml(placeholder),
  {
    allowedTags: sanitizeHtml.defaults.allowedTags.concat([
      'h1', 'h2', 'h3', 'h4', 'h5', 'h6',
      'p', 'br', 'ul', 'ol', 'li', 'pre', 'code', 'blockquote', 'strong', 'em',
    ]),
    allowedAttributes: {
      ...sanitizeHtml.defaults.allowedAttributes,
      a: ['href', 'title', 'target', 'rel'],
    },
  }
)
---

<Layout channel={channel} currentChannel={null}>
  <Header channel={channel} />

  <main class="about-page">
    <h2 class="about-title">About</h2>
    <div class="about-body" set:html={contentHtml}></div>
  </main>
</Layout>

<style>
  .about-page {
    max-width: 980px;
    margin: 0 auto;
    padding: 20px;
  }

  .about-title {
    margin: 0 0 12px;
    font-size: 20px;
    color: var(--text-color, #333);
  }

  .about-body {
    color: var(--text-color, #333);
    line-height: 1.7;
  }
</style>
