---
import List from '../../components/list.astro'
import { getPosts } from '../../lib/d1-client'

const { channel: channelName } = Astro.params

// 从 D1 获取帖子 (不再校验 CHANNELS 列表，允许访问任意频道)
let posts = []
let hasMoreBefore = false
try {
  posts = await getPosts(Astro, { channel: channelName, limit: 20 })
  // 第一页：如果返回了 20 条，说明还有更多
  hasMoreBefore = posts.length >= 20
} catch (e) {
  console.error(`Failed to fetch posts for ${channelName}:`, e)
}

// 单频道模式限制 10 页
const maxPages = 10

// 构造 channel 对象供 List 组件使用
const channelData = {
  username: channelName,
  title: channelName,
  description: '',
  descriptionHTML: '',
  avatar: null,
  avatarFallback: null,
  posts: posts.map(p => ({
    ...p,
    published_at: p.published_at || p.datetime,
    // 保持原有 post 结构兼容性
    id: p.id,
    channel: p.channel,
    title: p.title,
    content: p.content,
    datetime: p.published_at || p.datetime,
    tags: p.tags || [],
    type: 'text'
  }))
}
---

<List channel={channelData} currentChannel={channelName} after={false} hasMoreBefore={hasMoreBefore} maxPages={maxPages} currentPage={1} />
