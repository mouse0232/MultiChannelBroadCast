---
import List from '../../../../components/list.astro'
import { getPosts } from '../../../../lib/d1-client'
import { getEnv } from '../../../../lib/env'

const { channel: channelName, cursor } = Astro.params

// 验证频道
const channelsStr = getEnv(import.meta.env, Astro, 'CHANNELS') || getEnv(import.meta.env, Astro, 'CHANNEL')
const channels = channelsStr ? channelsStr.split(',').map(c => c.trim()).filter(Boolean) : []

if (channels.length > 0 && !channels.includes(channelName)) {
  // return Astro.redirect('/404')
}

// 获取帖子
let posts = []
let hasMore = false
try {
  posts = await getPosts(Astro, { channel: channelName, limit: 20, before: cursor })
  // 检查是否还有更多数据：如果返回了20条，说明可能还有更多
  hasMore = posts.length >= 20
} catch (e) {
  console.error(`Failed to fetch posts for ${channelName}:`, e)
}

const channelData = {
  username: channelName,
  title: channelName,
  description: '',
  posts: posts.map(p => ({
    ...p,
    datetime: p.published_at || p.datetime,
    id: p.id,
    channel: p.channel,
    title: p.title,
    content: p.content
  }))
}
---

<List channel={channelData} currentChannel={channelName} hasMoreBefore={hasMore} />
