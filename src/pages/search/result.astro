---
import List from '../../components/list.astro'
import { getEnv } from '../../lib/env'
import { searchPosts } from '../../lib/d1-client'

const q = Astro.url.searchParams.get('q') || ''
const scopeParam = Astro.url.searchParams.get('scope') || 'all'
const requestedChannel = Astro.url.searchParams.get('channel') || ''

const scope = scopeParam === 'channel' && requestedChannel ? 'channel' : 'all'
const channelName = scope === 'channel' ? requestedChannel : 'all'

const siteName = getEnv(import.meta.env, Astro, 'SITE_NAME') || 'Multi-Channel Broadcast'

let posts = []
try {
  // 直连 D1 搜索帖子
  posts = await searchPosts(Astro, q, { channel: channelName, limit: 50 }) || []
} catch (e) {
  console.error('Search failed:', e)
}

const channelData = {
  username: scope === 'channel' ? requestedChannel : '',
  title: q,
  description: `Search results for "${q}"`,
  posts: posts.map(p => ({
    ...p,
    datetime: p.published_at || p.datetime,
    id: p.id,
    channel: p.channel,
    title: p.title,
    content: p.content
  }))
}

channelData.seo = {
  title: `${q} - Search`,
  noindex: true,
  nofollow: true,
}
---

<List channel={channelData} currentChannel={scope === 'channel' ? requestedChannel : null} before={false} after={false} />
