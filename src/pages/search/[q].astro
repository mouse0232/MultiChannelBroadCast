---
import List from '../../components/list.astro'
import { getChannelInfo } from '../../lib/telegram'

const { q } = Astro.params

const channel = await getChannelInfo(Astro, { q })

channel.seo = {
  title: q,
  noindex: true,
  nofollow: true,
}
---

<List channel={channel} before={false} after={false} />
