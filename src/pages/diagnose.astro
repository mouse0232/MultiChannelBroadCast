---
import Layout from '../layouts/base.astro'
import { getSingleChannelInfo } from '../lib/telegram'
import { getEnv } from '../lib/env'

// 获取第一个频道作为示例
const channelsStr = getEnv(import.meta.env, Astro, 'CHANNELS') || getEnv(import.meta.env, Astro, 'CHANNEL')
const channels = channelsStr ? channelsStr.split(',').map(c => c.trim()).filter(Boolean) : []
const firstChannel = channels[0] || 'unknown'

const channel = channels.length > 0 ? await getSingleChannelInfo(Astro, firstChannel) : null
const posts = channel?.posts || []

const info = {
  channelTitle: channel?.title,
  channelUsername: channel?.username,
  postsCount: posts.length,
  firstPost: posts[0] ? {
    id: posts[0].id,
    channel: posts[0].channel,
    title: posts[0].title?.substring(0, 50),
    hasContent: !!posts[0].content,
    datetime: posts[0].datetime,
  } : null,
  environment: {
    CHANNELS: channelsStr,
    SITE_NAME: getEnv(import.meta.env, Astro, 'SITE_NAME'),
    SITE_URL: Astro.locals.SITE_URL,
    origin: Astro.url.origin,
    pathname: Astro.url.pathname,
  }
}
---

<Layout channel={channel}>
  <div style="padding: 20px; font-family: monospace; font-size: 12px;">
    <h1>诊断信息</h1>
    
    <h2>缓存配置</h2>
    <pre>{JSON.stringify({
      type: 'BroadcastChannel Simple Cache',
      ttl: '5 minutes',
      maxSize: '50MB',
      strategy: 'LRU',
    }, null, 2)}</pre>
    
    <h2>当前频道数据</h2>
    <pre>{JSON.stringify({
      title: info.channelTitle,
      username: info.channelUsername,
      postsCount: info.postsCount,
      firstPost: info.firstPost,
    }, null, 2)}</pre>
    
    <h2>环境配置</h2>
    <pre>{JSON.stringify(info.environment, null, 2)}</pre>
    
    <h2>已配置频道</h2>
    <ul>
      {channels.map(ch => <li>{ch}</li>)}
    </ul>
  </div>
</Layout>
