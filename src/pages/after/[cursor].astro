---
import List from '../../components/list.astro'
import { getPosts } from '../../lib/d1-client'
import { getEnv } from '../../lib/env'

const { cursor } = Astro.params
// cursor 已经过 URL 编码，直接使用（fetch 会自动处理）

const siteName = getEnv(import.meta.env, Astro, 'SITE_NAME') || 'Multi-Channel Broadcast'

// 获取所有频道的更新帖子 (cursor 是 published_at 的 after 参数)
let posts = []
try {
  posts = await getPosts(Astro, { channel: 'all', limit: 20, after: cursor })
} catch (e) {
  console.error('Failed to fetch posts:', e)
}

const channelData = {
  title: siteName,
  description: '',
  username: '',
  posts: posts.map(p => ({
    ...p,
    datetime: p.published_at || p.datetime,
    id: p.id,
    channel: p.channel,
    title: p.title,
    content: p.content
  }))
}
---

<List channel={channelData} currentChannel={null} />
