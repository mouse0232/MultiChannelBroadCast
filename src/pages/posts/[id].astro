---
import List from '../../components/list.astro'
import { getEnv } from '../../lib/env'
import { getWorkerBaseUrl } from '../../lib/d1-client'

const { id } = Astro.params

// 从 D1 获取帖子
// id 可能是纯数字，也可能是 channel/123 格式
let post = null
let channelUsername = ''
let channelTitle = ''

try {
  const baseUrl = getWorkerBaseUrl(Astro)
  // 提取数字部分用于查询
  const numericId = id.includes('/') ? id.split('/').pop() : id
  
  const res = await fetch(`${baseUrl}/api/post/${numericId}`)
  if (res.ok) {
    const data = await res.json()
    post = data.post
    if (post) {
      channelUsername = post.channel
      channelTitle = post.channel
      // 保持 post.channel 字段供 List 组件使用
    }
  }
} catch (e) {
  console.error('Failed to fetch post:', e)
}

if (!post) {
  return Astro.redirect('/404')
}

// 读取频道名称映射
const channelNameMap = new Map()
const channelNamesEnv = getEnv(import.meta.env, Astro, 'CHANNEL_NAMES')
if (channelNamesEnv) {
  channelNamesEnv.split(';').forEach(pair => {
    const [username, displayName] = pair.split(':')
    if (username && displayName) {
      channelNameMap.set(username.trim(), displayName.trim())
    }
  })
}

const channelDisplayName = channelNameMap.get(channelUsername) || channelTitle || channelUsername

const channel = {
  posts: [post],
  title: channelDisplayName,
  username: channelUsername,
  avatar: null, // D1 currently doesn't store avatar
  seo: {
    title: post.title,
    text: post.text || post.content?.replace(/<[^>]*>/g, '').substring(0, 100),
  }
}
---

<List channel={channel} isItem={true} before={false} after={false} />
