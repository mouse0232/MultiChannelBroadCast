---
import List from '../../components/list.astro'
import { getEnv } from '../../lib/env'
import { getWorkerBaseUrl } from '../../lib/d1-client'

const { id } = Astro.params
// id 是 URL 编码的完整 ID，如 "yunyoocc%2F12345" -> "yunyoocc/12345"
const decodedId = decodeURIComponent(id)

// 从 D1 获取帖子
let post = null
let channelUsername = ''
let channelTitle = ''

try {
  const baseUrl = getWorkerBaseUrl(Astro)
  // 使用完整 ID 精确查询
  const res = await fetch(`${baseUrl}/api/post/${encodeURIComponent(decodedId)}`)
  if (res.ok) {
    const data = await res.json()
    post = data.post
    if (post) {
      channelUsername = post.channel
      channelTitle = post.channel
    }
  }
} catch (e) {
  console.error('Failed to fetch post:', e)
}

if (!post) {
  return Astro.redirect('/404')
}

// 读取频道名称映射
const channelNameMap = new Map()
const channelNamesEnv = getEnv(import.meta.env, Astro, 'CHANNEL_NAMES')
if (channelNamesEnv) {
  channelNamesEnv.split(';').forEach(pair => {
    const [username, displayName] = pair.split(':')
    if (username && displayName) {
      channelNameMap.set(username.trim(), displayName.trim())
    }
  })
}

const channelDisplayName = channelNameMap.get(channelUsername) || channelTitle || channelUsername

// 提取帖子首图用于 OG 预览
const postImageMatch = post.content?.match(/<img[^>]+src=["']([^"']+)["']/i)
const postImage = postImageMatch ? postImageMatch[1] : null

const channel = {
  posts: [post],
  title: channelDisplayName,
  username: channelUsername,
  avatar: postImage || null, // 优先使用帖子首图作为预览图
  seo: {
    title: post.title,
    text: post.text || post.content?.replace(/<[^>]*>/g, '').substring(0, 150),
  }
}
---

<List channel={channel} isItem={true} before={false} after={false} />
