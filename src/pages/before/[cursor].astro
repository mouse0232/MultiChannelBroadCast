---
import List from '../../components/list.astro'
import { getPosts } from '../../lib/d1-client'
import { getEnv } from '../../lib/env'

const { cursor } = Astro.params
// cursor 已经过 URL 编码，直接使用（fetch 会自动处理）

// 读取 URL 中的频道过滤参数
const filterChannel = Astro.url.searchParams.get('channel') || 'all'
const siteName = getEnv(import.meta.env, Astro, 'SITE_NAME') || 'Multi-Channel Broadcast'

// 分页逻辑：获取当前页码，默认为 1
const currentPageParam = Astro.url.searchParams.get('page') || '1'
const currentPage = parseInt(currentPageParam, 10)

// 聚合模式（首页无筛选）限制 100 页，单频道模式限制 10 页
const maxPages = filterChannel !== 'all' ? 10 : 100

// 获取指定频道的更早帖子
let posts = []
let hasMore = false
try {
  posts = await getPosts(Astro, { channel: filterChannel, limit: 20, before: cursor })
  // 检查是否还有更多数据：如果返回了 20 条，说明可能还有更多
  // 同时也检查是否达到页数上限
  hasMore = posts.length >= 20 && currentPage < maxPages
} catch (e) {
  console.error('Failed to fetch posts:', e)
}

const channelData = {
  title: siteName,
  description: '',
  username: filterChannel !== 'all' ? filterChannel : 'all',
  posts: posts.map(p => ({
    ...p,
    published_at: p.published_at || p.datetime,
    datetime: p.published_at || p.datetime,
    id: p.id,
    channel: p.channel,
    title: p.title,
    content: p.content
  }))
}
---

<List channel={channelData} currentChannel={null} hasMoreBefore={hasMore} maxPages={maxPages} currentPage={currentPage} />
