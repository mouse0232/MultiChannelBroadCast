---
import Layout from '../layouts/base.astro'
import Header from '../components/header.astro'
import { getEnv } from '../lib/env'
import { getChannels } from '../lib/d1-client'

// 读取频道配置 (用于 fallback 或排序)
const channelsStr = getEnv(import.meta.env, Astro, 'CHANNELS') || getEnv(import.meta.env, Astro, 'CHANNEL')
const configuredChannels = channelsStr ? channelsStr.split(',').map(c => c.trim()).filter(Boolean) : []

const { SITE_URL, SITE_NAME, SITE_AVATAR } = Astro.locals

// 从 Worker API 获取频道信息 (替代旧的实时抓取)
// 注意：这依赖于环境变量 WORKER_URL 或默认的 Worker 地址
let channelInfos = []
try {
  const channelsFromDb = await getChannels(Astro)
  
  // 格式化数据供前端展示
  channelInfos = channelsFromDb.map(ch => ({
    username: ch.channel,
    title: ch.title || ch.channel, // 优先显示数据库中的昵称
    avatar: ch.avatar || ''       // 优先显示数据库中的头像
  }))

  // 如果有配置的频道列表但 D1 中还没有数据 (首次运行)，使用配置列表作为 fallback
  if (channelInfos.length === 0 && configuredChannels.length > 0) {
    channelInfos = configuredChannels.map(ch => ({
      username: ch,
      title: ch,
      avatar: ''
    }))
  }
} catch (e) {
  console.error('Failed to fetch channels from D1:', e)
  // Fallback to env config
  if (configuredChannels.length > 0) {
    channelInfos = configuredChannels.map(ch => ({ username: ch, title: ch, avatar: '' }))
  }
}

// 如果还是空的，可能未配置
if (channelInfos.length === 0) {
  // 这里不直接 redirect 404，因为可能 Worker 还没部署好，给用户一个空状态提示更好
  // 但为了保持原有逻辑：
  // return Astro.redirect('/404') 
}

const siteHeader = {
  title: SITE_NAME || 'Multi-Channel Broadcast',
  avatar: SITE_AVATAR || null
}

---

<Layout channel={siteHeader} currentChannel={null}>
  <Header channel={siteHeader} showGlobalRss={true} rssUrl={`${SITE_URL}rss.xml`} />

  <main class="home-channels">
    <h2 class="home-title">频道列表</h2>
    <div class="channel-grid">
      {channelInfos.map((info) => (
        <a class="channel-card" href={`${SITE_URL}channel/${info.username}`} title={info.title}>
          <div class="avatar-wrap">
            {info.avatar ? (
              <img src={info.avatar} alt={info.title} loading="lazy" />
            ) : (
              <div class="avatar-fallback">@</div>
            )}
          </div>
          <div class="card-body">
            <div class="card-title">{info.title}</div>
            <div class="card-username">@{info.username}</div>
          </div>
        </a>
      ))}
    </div>
  </main>

</Layout>

<style>
  .home-channels {
    max-width: 980px;
    margin: 0 auto;
    padding: 20px;
  }

  .home-title {
    font-size: 20px;
    margin: 8px 0 16px;
    color: var(--text-color, #333);
  }

  .channel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }

  .channel-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    background: var(--card-bg, #fff);
    border: 1px solid var(--border-color, #e9e9e9);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }

  .channel-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.06);
  }

  .avatar-wrap {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background: var(--avatar-bg, #f5f5f5);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-fallback {
    font-weight: 600;
    color: var(--secondary-color, #666);
  }

  .card-body {
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-weight: 600;
    font-size: 15px;
    color: var(--text-color, #333);
  }

  .card-username {
    font-size: 13px;
    color: var(--secondary-color, #777);
  }

  @media (max-width: 600px) {
    .channel-card { padding: 10px }
    .avatar-wrap { width: 48px; height: 48px }
  }
</style>
---
