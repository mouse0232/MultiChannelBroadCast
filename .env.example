## =====================================
## 核心配置
## =====================================

## 多频道配置 - 使用英文逗号分隔多个频道 (必需)
## 示例: CHANNELS=miantiao_me,v2ex,telegram
CHANNELS=miantiao_me,zaihuapd,sspai,zaobao_news,AI_News_CN,tnews365,kkaifenxiang,

## 或者使用单个频道 (向下兼容BroadcastChannel)
# CHANNEL=your_channel_name

## 站点名称
SITE_NAME=Multi-Channel Broadcast

## 站点URL (可选,部署平台会自动设置)
# SITE=https://your-domain.com

## 站点头像 (自定义站点图标,优先于频道头像)
## 支持完整URL或相对路径,如: https://example.com/avatar.png 或 /favicon.svg
## 示例: SITE_AVATAR=https://linux.do/user_avatar/linux.do/banlan/288/1119097_2.png
# SITE_AVATAR=/favicon.svg

## 频道显示名称映射 (可选)
## 格式: 频道用户名:显示名称;频道用户名2:显示名称2
## 示例: CHANNEL_NAMES=miantiao_me:面条实验室;v2ex:V2EX
# CHANNEL_NAMES=channel1:频道1;channel2:频道2

## =====================================
## 语言和时区
## =====================================

## 语言代码 (参考 dayjs 支持的语言)
LOCALE=zh-cn

## 时区设置
TIMEZONE=Asia/Shanghai

## =====================================
## 社交媒体配置
## =====================================

## Telegram 用户名 (不含@)
TELEGRAM=

## Twitter/X 用户名 (不含@)
TWITTER=

## GitHub 用户名
GITHUB=banlanzs

## Mastodon 完整URL
# MASTODON=https://mastodon.social/@username

## Bluesky 完整URL
# BLUESKY=https://bsky.app/profile/username

## Discord 邀请链接
# DISCORD=https://discord.gg/invite

## 播客链接
# PODCAST=https://your-podcast.com

## =====================================
## SEO 配置
## =====================================

## 是否禁止搜索引擎跟踪链接
NOFOLLOW=false

## 是否禁止搜索引擎索引
NOINDEX=false

## 启用 Google 站内搜索 (填写域名)
# GOOGLE_SEARCH_SITE=your-domain.com

## 启用标签页面 (使用英文逗号分隔)
# TAGS=技术,生活,随笔

## =====================================
## 链接和导航
## =====================================

## 友情链接 (格式: 标题,URL;标题2,URL2)
# LINKS=GitHub,https://github.com/yourname;博客,https://blog.com

## 侧边栏导航项 (格式: 标题,URL;标题2,URL2)
# NAVS=关于,/about;RSS,/rss.xml

## =====================================
## 高级配置
## =====================================

## Telegram 主机名 (支持配置多个，用英文逗号分隔，系统将随机选择以分担流量)
## 推荐组合: t.me,telegram.dog,telegram.me
TELEGRAM_HOST=t.me,telegram.dog

## 静态资源代理前缀 (可选,用于代理图片视频等)
# STATIC_PROXY=/static/

## 启用 Telegram 评论功能 (在帖子详情页显示评论区)
## 设置为 true 启用,false 或留空禁用
COMMENTS=true

## =====================================
## Telegram 推送功能 (可选)
## =====================================

## 启用 Telegram 推送 (将新消息推送到指定频道)
## 设置为 true 启用推送功能
# TELEGRAM_PUSH_ENABLED=true

## Telegram Bot Token (用于发送消息)
## 通过 @BotFather 创建机器人后获取
# TELEGRAM_BOT_TOKEN=your_bot_token_here

## 目标推送频道 ID (格式: @channelname 或 chat ID)
## 机器人需要是该频道的管理员或有发送消息权限
# TELEGRAM_PUSH_CHANNEL_ID=@your_channel_name

## =====================================
## 关键词过滤功能 (可选)
## =====================================

## 启用关键词过滤 (true/false)
## 默认：false (不启用)
## 过滤规则定义在 filter-rules.json 文件中
# FILTER_ENABLED=false

## =====================================

## Telegram 主机名 (重复项，建议删除，若保留需保持一致)
## 支持配置多个，用英文逗号分隔
TELEGRAM_HOST=t.me,telegram.dog

## 静态资源代理前缀 (可选,用于代理图片视频等)
# STATIC_PROXY=/static/

## 启用 Telegram 评论功能 (在帖子详情页显示评论区)
## 设置为 true 启用,false 或留空禁用
COMMENTS=true

## 页面头部注入代码 (支持 HTML,如 Google Analytics)
# HEADER_INJECT=<!-- Your header code -->

## 页面底部注入代码 (支持 HTML,如统计代码)
# FOOTER_INJECT=<!-- Your footer code -->

## =====================================
## Sentry 错误追踪 (可选)
## =====================================

# SENTRY_DSN=your_sentry_dsn
# SENTRY_PROJECT=your_project_name
# SENTRY_AUTH_TOKEN=your_auth_token

## =====================================
## 部署平台适配器 (可选)
## =====================================

## 指定部署适配器: vercel, cloudflare_pages, netlify, node
## 通常会自动检测,无需手动设置
# SERVER_ADAPTER=vercel

## =====================================
## RSS 配置
## =====================================

## 是否美化 RSS 输出
# RSS_BEAUTIFY=true

## =====================================
## 缓存配置
## =====================================

## 预构建缓存: 在构建时预加载数据到缓存中
## 这样部署后用户访问站点时可以直接显示内容，无需等待数据加载
# PREBUILD_CACHE=true

## 后台定时更新缓存的时间间隔(分钟)
## 设置为0或负数禁用后台更新
# CACHE_UPDATE_INTERVAL=30

## =====================================
## 调试和日志配置
## =====================================

## 启用 API 请求日志（用于调试和监控）
## 设置为 true 启用详细日志，false 或留空禁用
# API_LOGGING_ENABLED=false

## =====================================
## Docker 配置 (Docker 部署时自动设置)
## =====================================

# DOCKER=true
# HOST=0.0.0.0
# PORT=4321